# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# Server
PORT=8000

# URL frontend yang digunakan pada tautan reset password
FRONTEND_URL="http://localhost:5173"

# JWT — ganti dengan random string yang kuat (min 32 karakter)
JWT_SECRET="ganti_dengan_secret_yang_aman_dan_panjang"

# Nominal kupon referral dalam Rupiah (default 10000)
REFERRAL_COUPON_DISCOUNT=10000

# Email notifikasi transaksi dan reset password (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="mailer@example.com"
SMTP_PASS="smtp_password"
SMTP_FROM="Evora <mailer@example.com>"
